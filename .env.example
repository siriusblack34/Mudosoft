# ==============================================================================
# MudoSoft Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to source control!
# ==============================================================================

# Database
DB_PASSWORD=your_secure_database_password_here

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_minimum_32_characters_long
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here
AGENT_API_KEY=your_agent_api_key_here

# SQL Connections (for POS devices)
GENIUS_DB_USER=GENIUS3
GENIUS_DB_PASSWORD=your_genius_password_here
