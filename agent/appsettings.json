{
  "Agent": {
    "DeviceId": "DEV-002",
    "BackendUrl": "http://10.0.210.99:5102",
    "StoreCode": "150",
    "HeartbeatIntervalSeconds": 5,
    "CommandPollIntervalSeconds": 1,
    "IpAddress": "",
    "Collectors": {
      "PortMonitor": {
        "Enabled": true,
        "IntervalSeconds": 60,
        "Ports": [
          { "Port": 1433, "ServiceName": "SQL Server" },
          { "Port": 3389, "ServiceName": "RDP" }
        ],
        "TimeoutMs": 3000
      },
      "ProcessUsage": {
        "Enabled": true,
        "IntervalSeconds": 60,
        "TopCount": 10
      },
      "ServiceMonitor": {
        "Enabled": true,
        "IntervalSeconds": 60,
        "MonitoredServices": [ "MSSQL$SQLEXPRESS", "SQLBrowser" ],
        "AutoRestart": true,
        "MaxRestartsPerHour": 3
      },
      "EventLog": {
        "Enabled": true,
        "IntervalSeconds": 300,
        "LogNames": [ "System", "Application" ],
        "MaxEventsPerCycle": 50
      },
      "DiskHealth": {
        "Enabled": true,
        "IntervalSeconds": 3600
      },
      "WindowsUpdate": {
        "Enabled": true,
        "IntervalSeconds": 3600
      },
      "Temperature": {
        "Enabled": true,
        "IntervalSeconds": 60
      },
      "UpsStatus": {
        "Enabled": true,
        "IntervalSeconds": 30
      },
      "NetworkSpeed": {
        "Enabled": true,
        "IntervalSeconds": 3600,
        "TestUrl": "http://speedtest.tele2.net/10MB.zip",
        "TimeoutSeconds": 30
      },
      "UptimeReport": {
        "Enabled": true,
        "IntervalSeconds": 600
      },
      "ScheduledCleanup": {
        "Enabled": true,
        "IntervalSeconds": 86400,
        "Targets": [
          { "Path": "%TEMP%", "MaxAgeDays": 7 },
          { "Path": "C:\\Windows\\Temp", "MaxAgeDays": 7 },
          { "Path": "C:\\Windows\\Logs\\CBS", "MaxAgeDays": 30 }
        ]
      }
    }
  }
}
