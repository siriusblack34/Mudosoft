{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mudosoft;Username=postgres;Password=${DB_PASSWORD};Pooling=true;"
  },
  
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "MudoSoft",
    "Audience": "MudoSoftUsers",
    "AdminUsername": "${ADMIN_USERNAME}",
    "AdminPassword": "${ADMIN_PASSWORD}",
    "AgentApiKey": "${AGENT_API_KEY}",
    "ExpiryHours": 8
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MudoSoft": {
    "DataDirectory": "C:\\MudoSoft\\data",
    "Wmi": {
      "Domain": "MUDODMN",
      "Username": "mudoadmtd",
      "PasswordSecretKey": "MudoSoftWmiPassword",
      "Timeout": 5000
    }
  }
}