{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=orchestra;Username=postgres;Password=${DB_PASSWORD};Pooling=true;"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "Orchestra",
    "Audience": "OrchestraUsers",
    "AdminUsername": "${ADMIN_USERNAME}",
    "AdminPassword": "${ADMIN_PASSWORD}",
    "AgentApiKey": "${AGENT_API_KEY}",
    "ExpiryHours": 8
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://mudosoft.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Guacamole": {
    "GuacdHost": "localhost",
    "GuacdPort": 4822,
    "DefaultVncPort": 5900,
    "MaxConnections": 10
  },
  "CriticalServiceMonitor": {
    "Enabled": true,
    "IntervalSeconds": 300,
    "StartupDelaySeconds": 15,
    "ConfirmationThreshold": 2,
    "MaxConcurrency": 4,
    "WmiTimeoutSeconds": 8,
    "AutoStartStoppedServices": true,
    "ServiceStartTimeoutSeconds": 20,
    "ServiceStartPollIntervalMs": 1000,
    "DeviceTypes": [ "PC" ]
  },
  "MudoSoft": {
    "DataDirectory": "C:\\MudoSoft\\data",
    "Wmi": {
      "Domain": "MUDODMN",
      "Username": "mudoadmtd",
      "PasswordSecretKey": "MudoSoftWmiPassword",
      "Timeout": 5000
    }
  },
  "Ad": {
    "DomainControllers": [ "ADDC2.mudodmn.local" ],
    "_comment": "Yedek DC eklemek için bu listeye ekleyin: 'ADDC1.mudodmn.local'. Boş bırakılırsa Ldap:Server kullanılır."
  },
  "Internal": {
    "BaseUrl": "http://localhost:5102"
  },
  "Ldap": {
    "Enabled": true,
    "Server": "ADDC2.mudodmn.local",
    "Port": 389,
    "UseSsl": false,
    "Domain": "MUDODMN",
    "UpnSuffix": "@mudo.com.tr",
    "SearchBase": "DC=mudodmn,DC=local",
    "TimeoutMs": 5000,
    "DefaultRole": "Teknisyen"
  }
}
